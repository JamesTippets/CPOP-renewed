<UserControl x:Class="LoiterScan.App.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0 0 0 4">
            <!-- Title row -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <TextBlock Text="Catalog" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0 0 16 0"/>
                <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} objects'}"
                           Foreground="#555" VerticalAlignment="Center" Margin="0 0 12 0"/>
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Padding="4 2" VerticalContentAlignment="Center"/>
                <Button Content="Clear" Command="{Binding ClearFilterCommand}"
                        Margin="4 0 8 0" Padding="8 3"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Padding="8 3"/>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6" Margin="16 0 0 0"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
            <!-- Metadata coverage row -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <TextBlock Foreground="#555" FontSize="11">
                    <Run Text="Owner: "/>
                    <Run Text="{Binding OwnerCount}" FontWeight="SemiBold"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalCount}"/>
                    <Run Text="    Type: "/>
                    <Run Text="{Binding TypeCount}" FontWeight="SemiBold"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalCount}"/>
                </TextBlock>
                <TextBlock Foreground="#888" FontSize="11" Margin="16 0 0 0"
                           Text="{Binding LastIngested, StringFormat='Last ingested: {0}'}"
                           Visibility="{Binding LastIngested, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
            </StackPanel>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Objects}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  EnableRowVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="NORAD ID"     Binding="{Binding NoradId}"                            Width="90"/>
                <DataGridTextColumn Header="Name"         Binding="{Binding Name}"                               Width="200"/>
                <DataGridTextColumn Header="Owner"        Binding="{Binding Owner}"                              Width="80"/>
                <DataGridTextColumn Header="Type"         Binding="{Binding ObjectType}"                         Width="90"/>
                <DataGridTextColumn Header="Regime"       Binding="{Binding Regime}"                             Width="90"/>
                <DataGridTextColumn Header="Inc (°)"      Binding="{Binding InclinationDeg, StringFormat='F1'}"  Width="70"/>
                <DataGridTextColumn Header="Perigee (km)" Binding="{Binding PerigeeKm,  StringFormat='F0'}"     Width="95"/>
                <DataGridTextColumn Header="Apogee (km)"  Binding="{Binding ApogeeKm,   StringFormat='F0'}"     Width="95"/>
                <DataGridTextColumn Header="Age (d)"      Binding="{Binding EpochAgeDays, StringFormat='F1'}"   Width="70"/>
                <DataGridCheckBoxColumn Header="Debris"   Binding="{Binding IsDebris}"                          Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
