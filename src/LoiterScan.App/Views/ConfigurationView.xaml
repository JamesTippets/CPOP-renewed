<UserControl x:Class="LoiterScan.App.Views.ConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LoiterScan.App.ViewModels">
    <DockPanel>
        <!-- Action bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DDD" BorderThickness="0 1 0 0" Padding="16 8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Save" Command="{Binding SaveCommand}"
                        Padding="16 6" Margin="0 0 8 0"
                        Background="#1565C0" Foreground="White" BorderBrush="Transparent"/>
                <Button Content="Reload" Command="{Binding ReloadCommand}" Padding="12 6"/>
                <TextBlock Text="{Binding ValidationError}" Foreground="#C62828"
                           VerticalAlignment="Center" Margin="16 0 0 0"
                           Visibility="{Binding ValidationError, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                <TextBlock Text="{Binding SaveStatus}" Foreground="#2E7D32"
                           VerticalAlignment="Center" Margin="16 0 0 0"
                           Visibility="{Binding SaveStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16" MaxWidth="680">

                <!-- Cascade thresholds -->
                <TextBlock Text="Cascade" FontSize="14" FontWeight="Bold" Margin="0 0 0 8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0 0 0 16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Horizon (days)"            VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding HorizonDays}"      Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Coarse step (min)"          VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding CoarseStep}"        Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Coarse threshold (km)"      VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding CoarseThreshold}"   Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Fine step (min)"             VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding FineStep}"           Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Fine threshold (km)"          VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding FineThreshold}"      Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Detection step (min)"         VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding DetectionStep}"      Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Detection threshold (km)"     VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding DetectionThreshold}" Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Min loiter duration (min)"    VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="7" Grid.Column="1" Text="{Binding LoiterMinDuration}"  Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Loiter excursion allowance (min)" VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="8" Grid.Column="1" Text="{Binding LoiterExcursion}"    Margin="0 4" Padding="4 2"/>
                    </Grid>
                </Border>

                <!-- Phase buffers -->
                <TextBlock Text="Phase Buffers" FontSize="14" FontWeight="Bold" Margin="0 0 0 8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0 0 0 16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Coarse→Fine buffer (min)"     VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding CoarseToFine}"        Margin="0 4" Padding="4 2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Fine→Detection buffer (min)"   VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding FineToDetection}"      Margin="0 4" Padding="4 2"/>
                    </Grid>
                </Border>

                <!-- Pre-filter -->
                <TextBlock Text="Pre-filter" FontSize="14" FontWeight="Bold" Margin="0 0 0 8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0 0 0 16">
                    <StackPanel>
                        <CheckBox Content="Exclude debris objects" IsChecked="{Binding ExcludeDebris}" Margin="0 0 0 8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Regime scope:" VerticalAlignment="Center" Width="120"/>
                            <TextBox Text="{Binding RegimeScope}" Width="120" Padding="4 2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Acquisition -->
                <TextBlock Text="Acquisition" FontSize="14" FontWeight="Bold" Margin="0 0 0 8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0 0 0 16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                            <TextBlock Text="Data source:" VerticalAlignment="Center" Width="120"/>
                            <ComboBox Width="140"
                                      ItemsSource="{x:Static local:ConfigurationViewModel.DataSources}"
                                      SelectedItem="{Binding AcquisitionSource}"
                                      Padding="4 2"/>
                        </StackPanel>

                        <!-- Credentials — visible only for sources that require auth -->
                        <StackPanel Visibility="{Binding CredentialsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                <TextBlock Text="Username:" VerticalAlignment="Center" Width="120"/>
                                <TextBox x:Name="UsernameBox"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" Padding="4 2"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                <TextBlock Text="Password:" VerticalAlignment="Center" Width="120"/>
                                <PasswordBox x:Name="PasswordBox"
                                             Width="200" Padding="4 2"
                                             PasswordChanged="PasswordBox_PasswordChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox Content="Refresh catalog before each run" IsChecked="{Binding RefreshBeforeRun}"/>
                    </StackPanel>
                </Border>

                <!-- Exclusion lists -->
                <TextBlock Text="Exclusion Lists" FontSize="14" FontWeight="Bold" Margin="0 0 0 8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="Excluded countries (one per line):" Margin="0 0 0 4"/>
                        <TextBox Text="{Binding ExcludedCountriesText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="72" Padding="4"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="0 0 0 12"/>
                        <TextBlock Text="Excluded groups (one per line):" Margin="0 0 0 4"/>
                        <TextBox Text="{Binding ExcludedGroupsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="72" Padding="4"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="0 0 0 12"/>
                        <TextBlock Text="Excluded NORAD IDs (one per line):" Margin="0 0 0 4"/>
                        <TextBox Text="{Binding ExcludedIdsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="72" Padding="4"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
