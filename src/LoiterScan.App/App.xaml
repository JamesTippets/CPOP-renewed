<Application x:Class="LoiterScan.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LoiterScan.App.ViewModels"
             xmlns:views="clr-namespace:LoiterScan.App.Views"
             xmlns:conv="clr-namespace:LoiterScan.App.Converters">
    <Application.Resources>

        <!-- Value converters -->
        <conv:InverseBoolConverter               x:Key="InverseBoolConverter"/>
        <conv:BoolToVisibilityConverter          x:Key="BoolToVisibilityConverter"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>

        <!-- Nav rail button style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#B0C8E8"/>
            <Setter Property="BorderBrush"                Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="16 10"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2F45"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View-model → view DataTemplates (view-model-first navigation) -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
            <views:ResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventDetailViewModel}">
            <views:EventDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
            <views:CatalogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigurationViewModel}">
            <views:ConfigurationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AnalyticsViewModel}">
            <views:AnalyticsView/>
        </DataTemplate>

    </Application.Resources>
</Application>
